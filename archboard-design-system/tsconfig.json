{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "components/ui/**/*.ts",
    "components/ui/**/*.tsx",
    "tokens/**/*.ts"
  ]
}
